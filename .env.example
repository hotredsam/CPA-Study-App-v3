# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cpa_study"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="cpa-study-recordings"
R2_PUBLIC_URL=""

# Trigger.dev
TRIGGER_PROJECT_ID=""
TRIGGER_SECRET_KEY=""

# OpenRouter / indexing
OPENROUTER_API_KEY=""
OPENROUTER_PDF_ENGINE="mistral-ocr"
OPENROUTER_PDF_MODEL="anthropic/claude-haiku-4.5"
OPENROUTER_TEXTBOOK_HTML_MODEL="anthropic/claude-sonnet-4.6"
OPENROUTER_TEXTBOOK_HTML_MAX_TOKENS="6000"
TEXTBOOK_INDEXER_MODE="local"
ENCRYPTION_KEY=""
ANTHROPIC_API_KEY=""

# Whisper model path (optional — leave empty on Windows dev; use in Trigger.dev Linux container)
WHISPER_MODEL_PATH=""
WHISPER_PREPASS_MODEL_PATH=""

# Sentry — optional; leave blank for local dev (no-op when absent)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
